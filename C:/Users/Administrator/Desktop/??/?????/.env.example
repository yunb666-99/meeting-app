# ============================================
# MeetingApp 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================

# 服务器域名（需已备案）
DOMAIN=meeting.example.com

# 服务器公网 IP 地址（LiveKit WebRTC 需要）
SERVER_IP=1.2.3.4

# PostgreSQL 数据库密码（自动生成，勿泄露）
DB_PASSWORD=change-me-to-random-32-char

# Redis 密码（自动生成，勿泄露）
REDIS_PASSWORD=change-me-to-random-32-char

# JWT 签名密钥（自动生成，勿泄露）
JWT_ACCESS_SECRET=change-me-to-random-64-char
JWT_REFRESH_SECRET=change-me-to-random-64-char
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# LiveKit API 密钥（自动生成，勿泄露）
LIVEKIT_API_KEY=meetingapp-key
LIVEKIT_API_SECRET=change-me-to-random-64-char
